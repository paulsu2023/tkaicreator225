# Google Cloud Vertex AI 配置 (推荐)
# 需要创建具有 Vertex AI 使用权限的服务账号，并在 Vercel 中粘贴以下对应信息
GCP_PROJECT_ID=your_gcp_project_id
GCP_CLIENT_EMAIL=your_service_account_email@developer.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here...\n-----END PRIVATE KEY-----\n"

# 纯 API Key 模式 (备用方案)
# 如果上面的 GCP 配置为空，系统将回退使用这个单纯的 API Key
GEMINI_API_KEY=your_gemini_api_key_here
